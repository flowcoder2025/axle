# =
# AXLE — Environment Variables
# 생성일: 2026-04-10
# =

# --- Supabase (Database + Storage) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
DIRECT_URL=

# --- Auth.js v5 ---
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# --- Google OAuth (console.cloud.google.com > Credentials) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Google Calendar API (같은 GCP 프로젝트에서 Calendar API 활성화) ---
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# --- OAuth Token Encryption (generate with: openssl rand -hex 32) ---
OAUTH_ENCRYPTION_KEY=

# --- Scraper Credential Master Key (separate from OAuth key; generate with: openssl rand -hex 32) ---
# Encrypts ClientCertificate.pfxCiphertext / passwordCiphertext and ClientPortalAccount.passwordCiphertext
SCRAPER_CRED_MASTER_KEY=

# --- Upstash Redis (upstash.com > Redis > REST API) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Upstash QStash (upstash.com > QStash) ---
QSTASH_URL=
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# --- AI: Anthropic (console.anthropic.com) ---
ANTHROPIC_API_KEY=

# --- AI: OpenAI (platform.openai.com) ---
OPENAI_API_KEY=

# --- AI: Google Gemini (aistudio.google.com) ---
GOOGLE_GEMINI_API_KEY=

# --- Email: Resend (resend.com/api-keys) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# --- SMS/알림톡: Solapi (solapi.com > API Keys) ---
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER_PHONE=

# --- 공공데이터 API (data.go.kr > 마이페이지 > 인증키) ---
DATA_GO_KR_API_KEY=

# --- DART OpenAPI (opendart.fss.or.kr > 인증키) ---
DART_API_KEY=

# --- Telegram Bot (BotFather에서 생성) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Discord Webhook (서버 설정 > 연동 > 웹후크) ---
DISCORD_WEBHOOK_URL=

# --- Vercel Cron (자동 설정, 배포 시 주입) ---
CRON_SECRET=

# --- Unsubscribe (이메일 수신거부 HMAC) ---
UNSUBSCRIBE_SECRET=

# --- Sentry (선택: 미설정 시 Sentry 비활성화) ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# 릴리즈/소스맵 업로드 시 필요 (CI 빌드에서만 설정)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
NEXT_PUBLIC_SENTRY_ENV=
SENTRY_ENV=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=
SENTRY_TRACES_SAMPLE_RATE=
