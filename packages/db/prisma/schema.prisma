// AXLE — Prisma 7 Schema

datasource db {
  provider = "postgresql"
}

generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

// ========================================
// Auth/Org Models (WI-004)
// ========================================

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum PlatformRole {
  USER
  PLATFORM_ADMIN
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String       @unique
  emailVerified DateTime?
  image         String?
  password      String? // bcrypt hashed, null for OAuth-only users
  platformRole  PlatformRole @default(USER)
  isActive      Boolean      @default(true)

  accounts      Account[]
  sessions      Session[]
  memberships   Membership[]
  notifications Notification[]

  oauthTokens       OAuthToken[]
  assignedClients   Client[]           @relation("ClientAssignee")
  assignedProjects  Project[]          @relation("ProjectAssignee")
  pushSubscriptions PushSubscription[]
  hwpxTemplates     HwpxTemplate[]     @relation("HwpxTemplateCreator")

  // pbc-hr-payroll back-relations (WI-607).
  employments       Employment[]       @relation("EmploymentUser")
  attendances       Attendance[]       @relation("AttendanceUser")
  payrolls          Payroll[]          @relation("PayrollUser")
  leaves            Leave[]            @relation("LeaveUser")
  nomuConsultations NomuConsultation[] @relation("NomuUser")
  workSchedules     WorkSchedule[]     @relation("WorkScheduleUser")

  // Phase 20 ERP intake back-relation (WI-705).
  intakeDrafts IntakeDraft[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OAuthToken {
  id           String    @id @default(cuid())
  userId       String
  provider     String // e.g. "GOOGLE"
  accessToken  String    @db.Text // AES-256-GCM encrypted
  refreshToken String?   @db.Text // AES-256-GCM encrypted
  expiresAt    DateTime?
  scope        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Organization {
  id      String  @id @default(cuid())
  name    String
  slug    String  @unique
  logoUrl String?

  memberships    Membership[]
  clients        Client[]
  programs       ProgramInfo[]
  templates      ChecklistTemplate[]
  aiJobs         AiJob[]
  hwpxTemplates  HwpxTemplate[]
  scraperJobs    ScraperJob[]
  scraperApiKeys ScraperApiKey[]

  // pbc-hr-payroll back-relations (WI-607).
  employments       Employment[]       @relation("EmploymentOrg")
  attendances       Attendance[]       @relation("AttendanceOrg")
  payrolls          Payroll[]          @relation("PayrollOrg")
  leaves            Leave[]            @relation("LeaveOrg")
  nomuConsultations NomuConsultation[] @relation("NomuOrg")
  workSchedules     WorkSchedule[]     @relation("WorkScheduleOrg")

  plan         String  @default("free")
  quotaAiJobs  Int     @default(100)
  quotaMembers Int     @default(10)
  isSuspended  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Membership {
  id             String     @id @default(cuid())
  userId         String
  organizationId String
  role           MemberRole @default(MEMBER)

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, organizationId])
  @@index([organizationId])
}

// ========================================
// ReBAC Models (WI-008)
// ========================================

// Zanzibar-style relation tuple: subject has `relation` on object in namespace
model RelationTuple {
  id          String @id @default(cuid())
  namespace   String
  objectId    String
  relation    String
  subjectType String
  subjectId   String

  createdAt DateTime @default(now())

  @@unique([namespace, objectId, relation, subjectType, subjectId])
  @@index([subjectType, subjectId])
  @@index([namespace, objectId, relation])
}

// ========================================
// CRM Models (WI-005)
// ========================================

enum ClientStatus {
  ACTIVE
  INACTIVE
  PROSPECT
}

enum ContactSource {
  BUSINESS_CARD
  MANUAL
  IMPORT
}

enum AchievementType {
  PATENT
  AWARD
  CONTRACT
  INVESTMENT
  CERTIFICATION
}

enum ProgramCategory {
  STARTUP
  VENTURE
  RND
  CERTIFICATION
  EXPORT
  SMART_FACTORY
  GENERAL
}

model Client {
  id             String       @id @default(cuid())
  orgId          String
  name           String
  businessNumber String?
  ceoName        String?
  industry       String?
  address        String?
  phone          String?
  email          String?
  website        String?
  memo           String?
  status         ClientStatus @default(ACTIVE)
  assignedToId   String?
  assignedToUser User?        @relation("ClientAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)

  employeeCount      Int?
  capitalAmount      Decimal?
  foundedDate        DateTime?
  region             String?
  isVenture          Boolean   @default(false)
  isInnoBiz          Boolean   @default(false)
  isMainBiz          Boolean   @default(false)
  isSocial           Boolean   @default(false)
  ventureValidUntil  DateTime?
  businessStatus     String?
  businessVerifiedAt DateTime?
  corpCode           String?
  financialsSyncedAt DateTime?
  masterProfile      Json?
  profileBlocks      Json?
  onboardedAt        DateTime?

  contacts           Contact[]
  financials         ClientFinancial[]
  achievements       ClientAchievement[]
  certificates       Certificate[]
  projects           Project[]
  documents          Document[]
  journals           ResearchJournal[]
  meetings           Meeting[]
  financialReports   FinancialReport[]
  schedules          Schedule[]
  emailLogs          EmailLog[]
  estimates          Estimate[]
  contracts          Contract[]
  portalTokens       PortalToken[]
  portalCertificates ClientCertificate[]
  portalAccounts     ClientPortalAccount[]
  scraperJobs        ScraperJob[]

  organization Organization @relation(fields: [orgId], references: [id])
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([orgId])
  @@index([assignedToId])
}

model Contact {
  id              String        @id @default(cuid())
  clientId        String
  name            String
  position        String?
  department      String?
  phone           String?
  email           String?
  isPrimary       Boolean       @default(false)
  memo            String?
  source          ContactSource @default(MANUAL)
  businessCardUrl String?
  isResearcher    Boolean       @default(false)
  researchField   String?

  journals ResearchJournal[]

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model ClientFinancial {
  id               String   @id @default(cuid())
  clientId         String
  year             Int
  revenue          Decimal?
  operatingProfit  Decimal?
  netProfit        Decimal?
  totalAssets      Decimal?
  totalLiabilities Decimal?
  totalEquity      Decimal?
  creditRating     String?
  source           String?

  reports FinancialReport[]

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, year])
}

model ClientAchievement {
  id          String          @id @default(cuid())
  clientId    String
  type        AchievementType
  title       String
  date        DateTime?
  amount      Decimal?
  description String?
  documentId  String?

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model Certificate {
  id           String    @id @default(cuid())
  clientId     String
  type         String
  subjectName  String
  serialNumber String?
  validFrom    DateTime?
  validTo      DateTime?
  storagePath  String?
  isActive     Boolean   @default(true)

  client         Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  checklistItems ChecklistItem[]

  @@index([clientId])
}

model ProgramInfo {
  id                String          @id @default(cuid())
  orgId             String?
  name              String
  agency            String?
  category          ProgramCategory
  announcementUrl   String?
  announcementDocId String?
  applicationStart  DateTime?
  applicationEnd    DateTime?
  maxFunding        Decimal?
  requirements      Json?
  eligibility       Json?
  region            String?
  memo              String?
  isCrawled         Boolean         @default(false)
  crawledAt         DateTime?
  source            String?
  externalId        String?

  matchingResults MatchingResult[]
  schedules       Schedule[]

  organization Organization? @relation(fields: [orgId], references: [id])

  @@unique([source, externalId])
  @@index([orgId])
  @@index([source])
}

model MatchingResult {
  id                String   @id @default(cuid())
  clientId          String
  programId         String
  score             Decimal
  matchReasons      Json?
  disqualifyReasons Json?
  isRelevant        Boolean?
  feedbackNote      String?
  createdAt         DateTime @default(now())

  program ProgramInfo @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([programId])
}

// ========================================
// Project/Document Models (WI-006)
// ========================================

enum ProjectType {
  BUSINESS_PLAN
  VENTURE_CERT
  SOBOOJANG_CERT
  RESEARCH_INSTITUTE
  PATENT
  FINANCIAL_ANALYSIS
  RESEARCH_TASK
  BUNDLE
}

enum ProjectStatus {
  INTAKE
  DOC_COLLECTING
  IN_PROGRESS
  REVIEW
  SUBMITTED
  APPROVED
  REJECTED
  COMPLETED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum FeeType {
  FIXED
  SUCCESS_RATE
  MONTHLY
}

enum ProjectMemberRole {
  LEAD
  MEMBER
  VIEWER
}

enum DocCategory {
  INPUT
  OUTPUT
  TEMPLATE
  ISSUED
}

enum OcrStatus {
  NONE
  PROCESSING
  COMPLETED
  FAILED
}

enum DocStatus {
  PENDING
  REQUESTED
  UPLOADED
  VERIFIED
}

enum JournalStatus {
  DRAFT
  SUBMITTED
  APPROVED
}

model Project {
  id             String        @id @default(cuid())
  clientId       String
  programId      String?
  parentId       String?
  type           ProjectType
  title          String
  status         ProjectStatus @default(INTAKE)
  priority       Priority      @default(MEDIUM)
  assignedToId   String?
  assignedToUser User?         @relation("ProjectAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  dueDate        DateTime?
  submissionDate DateTime?
  memo           String?
  metadata       Json?

  feeType     FeeType?
  feeAmount   Decimal?
  successRate Decimal?
  isPaid      Boolean  @default(false)

  children     Project[]        @relation("ProjectTree")
  parent       Project?         @relation("ProjectTree", fields: [parentId], references: [id])
  members      ProjectMember[]
  checklist    ChecklistItem[]
  documents    Document[]
  meetings     Meeting[]
  aiJobs       AiJob[]
  estimates    Estimate[]
  contracts    Contract[]
  emailLogs    EmailLog[]
  comments     ProjectComment[]
  portalTokens PortalToken[]

  client    Client   @relation(fields: [clientId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([programId])
  @@index([assignedToId])
}

model ProjectMember {
  id        String            @id @default(cuid())
  projectId String
  userId    String
  role      ProjectMemberRole @default(MEMBER)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, userId])
}

model ChecklistTemplate {
  id          String      @id @default(cuid())
  orgId       String? /// Null = platform-wide shared template
  projectType ProjectType
  name        String
  description String?
  isRequired  Boolean     @default(true)
  sortOrder   Int         @default(0)

  organization Organization?           @relation(fields: [orgId], references: [id])
  items        ChecklistTemplateItem[]

  @@index([orgId, projectType])
  @@index([projectType])
}

model ChecklistTemplateItem {
  id              String            @id @default(cuid())
  templateId      String
  name            String
  description     String?
  isRequired      Boolean           @default(true)
  sortOrder       Int               @default(0)
  itemType        ChecklistItemType @default(DOCUMENT)
  certificateType String?

  template ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
}

model ChecklistItem {
  id              String            @id @default(cuid())
  projectId       String
  name            String
  description     String?
  isRequired      Boolean           @default(true)
  itemType        ChecklistItemType @default(DOCUMENT)
  status          DocStatus         @default(PENDING)
  requestedAt     DateTime?
  uploadedAt      DateTime?
  documentId      String?
  certificateId   String?
  certificateType String? /// Expected cert type (벤처기업확인서, 사업자등록증 등)

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  certificate Certificate? @relation(fields: [certificateId], references: [id])

  @@index([projectId])
}

enum ChecklistItemType {
  DOCUMENT
  CERTIFICATE
}

model Document {
  id             String      @id @default(cuid())
  clientId       String
  projectId      String?
  name           String
  fileUrl        String
  fileType       String
  category       DocCategory
  ocrStatus      OcrStatus   @default(NONE)
  ocrResult      Json?
  uploadToken    String?     @unique
  tokenExpiresAt DateTime?
  expiresAt      DateTime?
  autoRenew      Boolean     @default(false)
  version        Int         @default(1)
  parentDocId    String?
  verifyResult   Json?
  verifiedAt     DateTime?

  client    Client   @relation(fields: [clientId], references: [id])
  project   Project? @relation(fields: [projectId], references: [id])
  createdAt DateTime @default(now())

  @@index([clientId])
  @@index([projectId])
}

model DocumentEmbedding {
  id         String                      @id @default(cuid())
  sourceType String
  sourceId   String
  content    String
  embedding  Unsupported("vector(1536)")
  metadata   Json?

  @@unique([sourceType, sourceId])
}

model ResearchJournal {
  id                  String        @id @default(cuid())
  clientId            String
  researcherContactId String
  date                DateTime
  title               String
  content             String
  objectives          String?
  results             String?
  nextSteps           String?
  hours               Decimal?
  attachments         Json?
  status              JournalStatus @default(DRAFT)
  approvedBy          String?
  approvedAt          DateTime?
  aiDraftJobId        String?

  client     Client   @relation(fields: [clientId], references: [id])
  researcher Contact  @relation(fields: [researcherContactId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([clientId])
  @@index([researcherContactId])
}

// ========================================
// AI/Communication/Schedule Models (WI-007)
// ========================================

enum ScheduleType {
  DEADLINE
  MEETING
  REMINDER
  PROGRAM_DUE
}

enum AiJobType {
  BUSINESS_PLAN
  RESEARCH
  OCR
  TRANSCRIBE
  SUMMARY
  JOURNAL_DRAFT
  FINANCIAL_ANALYSIS
  GAP_DIAGNOSIS
  EVALUATION
  MATCHING
}

enum AiTier {
  LOCAL_MLX
  API_HAIKU
  API_OPUS
  CLI_CLAUDE
}

enum JobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum AutoType {
  HOMETAX_ISSUE
  MINWON24_ISSUE
  INSURANCE_ISSUE
  PORTAL_UPLOAD
  DART_FETCH
  CRAWL
}

enum NotificationType {
  DOC_REQUESTED
  DOC_UPLOADED
  DOC_EXPIRING
  DEADLINE
  MEETING_NOTIFY
  JOURNAL_DUE
  ACTION_ITEM
  ACTION_ITEM_DUE
  PROJECT_ASSIGNED
  MATCHING_RESULT
  AI_JOB_COMPLETE
  AI_JOB_FAILED
  PORTAL_COMPLETE
  HANDOFF
  ESTIMATE_SENT
  BUNDLE_COMPLETE
  MENTION
}

enum EmailType {
  DOC_REQUEST
  DOC_PUSH
  MEETING_SUMMARY
  ESTIMATE
  CONTRACT
  JOURNAL_REMINDER
  DEADLINE_ALERT
  MATCHING_DIGEST
  ONBOARDING
}

enum ActionStatus {
  OPEN
  IN_PROGRESS
  DONE
}

enum EstimateStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}

enum ContractStatus {
  DRAFT
  SENT
  SIGNED
  EXPIRED
}

model Meeting {
  id           String   @id @default(cuid())
  projectId    String?
  clientId     String
  title        String
  date         DateTime
  location     String?
  recordingUrl String?

  attendees   MeetingAttendee[]
  transcript  MeetingTranscript?
  actionItems ActionItem[]
  emailLogs   EmailLog[]

  client    Client   @relation(fields: [clientId], references: [id])
  project   Project? @relation(fields: [projectId], references: [id])
  createdAt DateTime @default(now())

  @@index([clientId])
  @@index([projectId])
}

model MeetingAttendee {
  id        String  @id @default(cuid())
  meetingId String
  contactId String?
  userId    String?
  name      String
  role      String?

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
}

model MeetingTranscript {
  id            String  @id @default(cuid())
  meetingId     String  @unique
  rawTranscript String
  summary       String?
  keyDecisions  Json?
  sentiment     String?
  aiJobId       String?

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
}

model ActionItem {
  id                String       @id @default(cuid())
  meetingId         String
  description       String
  assigneeUserId    String?
  assigneeContactId String?
  dueDate           DateTime?
  status            ActionStatus @default(OPEN)
  linkedChecklistId String?

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
}

model AiJob {
  id             String    @id @default(cuid())
  orgId          String
  projectId      String?
  type           AiJobType
  tier           AiTier
  status         JobStatus @default(QUEUED)
  input          Json
  output         Json?
  cost           Decimal?
  durationMs     Int?
  errorMessage   String?
  skillPatternId String?

  skillPattern SkillPattern? @relation(fields: [skillPatternId], references: [id])
  project      Project?      @relation(fields: [projectId], references: [id])
  organization Organization  @relation(fields: [orgId], references: [id])
  createdAt    DateTime      @default(now())

  @@index([orgId])
  @@index([projectId])
  @@index([type])
}

model SkillPattern {
  id                  String         @id @default(cuid())
  name                String
  taskType            String
  inputSchema         Json
  outputSchema        Json
  promptTemplate      String?
  successCount        Int            @default(0)
  lastUsedAt          DateTime?
  isFineTuned         Boolean        @default(false)
  status              FineTuneStatus @default(IDLE)
  errorMessage        String?
  sampleInput         Json?
  sampleOutput        Json?
  loraAdapterUrl      String?
  fineTuneStartedAt   DateTime?
  fineTuneCompletedAt DateTime?
  promotedAt          DateTime?

  aiJobs    AiJob[]
  createdAt DateTime @default(now())

  @@index([status])
  @@index([taskType, status])
}

enum FineTuneStatus {
  IDLE
  CANDIDATE
  QUEUED
  FINE_TUNING
  COMPLETED
  PROMOTED
  FAILED
}

model AutomationLog {
  id           String    @id @default(cuid())
  clientId     String?
  type         AutoType
  target       String
  status       JobStatus
  resultUrl    String?
  errorMessage String?
  detail       Json?
  executedAt   DateTime  @default(now())

  scraperJob ScraperJob?

  @@index([type, status])
  @@index([executedAt])
}

model Notification {
  id     String           @id @default(cuid())
  userId String
  type   NotificationType
  title  String
  body   String?
  link   String?
  isRead Boolean          @default(false)

  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([userId])
}

model EmailLog {
  id              String    @id @default(cuid())
  meetingId       String?
  clientId        String?
  projectId       String?
  to              String
  subject         String
  type            EmailType
  channel         String    @default("email")
  resendMessageId String?
  sentAt          DateTime  @default(now())
  openedAt        DateTime?

  meeting Meeting? @relation(fields: [meetingId], references: [id])
  client  Client?  @relation(fields: [clientId], references: [id])
  project Project? @relation(fields: [projectId], references: [id])

  @@index([clientId])
  @@index([meetingId])
  @@index([projectId])
}

model Schedule {
  id               String       @id @default(cuid())
  orgId            String
  clientId         String?
  projectId        String?
  programId        String?
  title            String
  description      String?
  type             ScheduleType
  startDate        DateTime
  endDate          DateTime?
  isAllDay         Boolean      @default(false)
  reminderDays     Int[]        @default([7, 3, 1])
  googleCalendarId String?

  client    Client?      @relation(fields: [clientId], references: [id])
  program   ProgramInfo? @relation(fields: [programId], references: [id])
  createdAt DateTime     @default(now())

  @@index([orgId])
  @@index([clientId])
  @@index([programId])
}

model FinancialReport {
  id                String  @id @default(cuid())
  clientId          String
  clientFinancialId String?
  year              Int
  analysis          Json?
  adjustments       Json?
  reportUrl         String?

  client          Client           @relation(fields: [clientId], references: [id])
  clientFinancial ClientFinancial? @relation(fields: [clientFinancialId], references: [id])
  createdAt       DateTime         @default(now())

  @@unique([clientId, year])
}

model Estimate {
  id             String         @id @default(cuid())
  projectId      String?
  clientId       String
  estimateNumber String         @unique
  items          Json
  totalAmount    Decimal
  taxAmount      Decimal?
  validUntil     DateTime?
  status         EstimateStatus @default(DRAFT)
  documentId     String?
  sentAt         DateTime?

  client    Client   @relation(fields: [clientId], references: [id])
  project   Project? @relation(fields: [projectId], references: [id])
  createdAt DateTime @default(now())

  @@index([clientId])
}

model Contract {
  id             String         @id @default(cuid())
  projectId      String?
  clientId       String
  contractNumber String         @unique
  title          String
  partyA         Json
  partyB         Json
  terms          Json
  totalAmount    Decimal?
  startDate      DateTime?
  endDate        DateTime?
  status         ContractStatus @default(DRAFT)
  documentId     String?
  signedAt       DateTime?

  client    Client   @relation(fields: [clientId], references: [id])
  project   Project? @relation(fields: [projectId], references: [id])
  createdAt DateTime @default(now())

  @@index([clientId])
}

// ========================================
// Collaboration Models (Phase 12)
// ========================================

model ProjectComment {
  id        String   @id @default(cuid())
  projectId String
  authorId  String
  body      String
  mentions  String[] // user IDs mentioned via @

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([authorId])
}

enum PortalTokenScope {
  FULL
  UPLOAD
  JOURNAL
}

model PortalToken {
  id        String           @id @default(cuid())
  token     String           @unique @default(cuid())
  projectId String?
  clientId  String
  scope     PortalTokenScope @default(FULL)
  expiresAt DateTime?
  createdBy String

  project   Project?        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  client    Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  journals  PortalJournal[]
  createdAt DateTime        @default(now())

  @@index([projectId])
  @@index([clientId])
}

model PortalJournal {
  id          String   @id @default(cuid())
  tokenId     String
  title       String
  content     String
  submittedAt DateTime @default(now())

  token PortalToken @relation(fields: [tokenId], references: [id], onDelete: Cascade)

  @@index([tokenId])
}

// ── Analytics ────────────────────────────────────────────────────────────────

enum EventCategory {
  PAGE_VIEW
  FEATURE_USE
  API_CALL
  SYSTEM
  BUSINESS
}

model AnalyticsEvent {
  id String @id @default(cuid())

  userId    String?
  orgId     String?
  sessionId String

  category EventCategory
  action   String
  label    String?
  value    Float?

  path     String?
  referrer String?

  metadata  Json?
  userAgent String?
  ip        String?

  createdAt DateTime @default(now())

  @@index([orgId, createdAt])
  @@index([category, createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([sessionId, createdAt])
}

model DailyMetric {
  id    String   @id @default(cuid())
  date  DateTime @db.Date
  orgId String?

  pageViews     Int @default(0)
  uniqueUsers   Int @default(0)
  sessions      Int @default(0)
  avgSessionSec Int @default(0)

  projectsCreated    Int @default(0)
  documentsProcessed Int @default(0)
  matchingsRun       Int @default(0)

  aiJobsTotal     Int   @default(0)
  aiJobsCost      Float @default(0)
  aiAvgDurationMs Int   @default(0)

  apiCalls           Int @default(0)
  apiErrors          Int @default(0)
  avgResponseMs      Int @default(0)
  automationRuns     Int @default(0)
  automationFailures Int @default(0)

  createdAt DateTime @default(now())

  @@unique([date, orgId])
  @@index([orgId, date])
}

model DailyActionMetric {
  id     String   @id @default(cuid())
  date   DateTime @db.Date
  orgId  String?
  action String
  count  Int      @default(0)

  @@unique([date, orgId, action])
  @@index([orgId, date])
  @@index([action, date])
}

// ── HWPX Templates (WI-208/WI-209) ───────────────────────────────────────────
// Government form templates stored in Supabase Storage with structured
// field→edit mappings used by POST /api/hwpx/edit to fill values.

enum HwpxTemplateCategory {
  VENTURE
  SOBOOJANG
  KOITA
  OTHER
}

model HwpxTemplate {
  id          String               @id @default(cuid())
  orgId       String?
  name        String
  description String?
  category    HwpxTemplateCategory @default(OTHER)
  storageKey  String
  fieldMap    Json
  version     Int                  @default(1)
  createdById String
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  org       Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy User          @relation("HwpxTemplateCreator", fields: [createdById], references: [id])

  @@index([orgId, category])
  @@index([createdById])
}

// ========================================
// Scraper / Portal automation (WI-318b)
// See .flowset/contracts/scraper-data.md
// ========================================

enum ScraperJobStatus {
  QUEUED
  PICKED_UP
  RUNNING
  COMPLETED
  FAILED
  EXPIRED
  CANCELLED
}

enum CredentialsKind {
  CERTIFICATE
  USERPW
}

enum PortalKind {
  HOMETAX
  MINWON24
  INSURANCE
}

model ScraperJob {
  id       String @id @default(cuid())
  orgId    String
  clientId String

  type   AutoType
  target String
  params Json?

  status         ScraperJobStatus @default(QUEUED)
  pickedUpAt     DateTime?
  pickedUpBy     String?
  leaseExpiresAt DateTime?
  completedAt    DateTime?

  credentialsKind CredentialsKind
  credentialsRef  String

  automationLogId String?        @unique
  automationLog   AutomationLog? @relation(fields: [automationLogId], references: [id])

  createdById String
  createdAt   DateTime @default(now())

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  client Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([orgId, status])
  @@index([status, leaseExpiresAt])
  @@index([clientId])
  @@index([createdById])
}

model ScraperApiKey {
  id          String    @id @default(cuid())
  orgId       String
  label       String
  tokenHash   String    @unique
  prefix      String
  lastUsedAt  DateTime?
  lastUsedIp  String?
  revokedAt   DateTime?
  createdById String
  createdAt   DateTime  @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([tokenHash])
}

model ClientCertificate {
  id                 String   @id @default(cuid())
  clientId           String
  subject            String
  issuer             String
  serialNumber       String
  validFrom          DateTime
  validTo            DateTime
  pfxCiphertext      String   @db.Text
  passwordCiphertext String   @db.Text
  createdById        String
  createdAt          DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([validTo])
}

model ClientPortalAccount {
  id                 String     @id @default(cuid())
  clientId           String
  portal             PortalKind
  userId             String
  passwordCiphertext String     @db.Text
  createdById        String
  createdAt          DateTime   @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, portal])
  @@index([clientId])
}

model ScraperRepairLog {
  id            String     @id @default(cuid())
  jobId         String?
  portal        PortalKind
  page          String
  element       String
  oldSelector   String
  newSelector   String
  repairedBy    String
  screenshotUrl String?
  createdAt     DateTime   @default(now())

  @@index([portal, createdAt])
  @@index([jobId])
}

// ========================================
// HR Payroll Domain (PBC: pbc-hr-payroll)
// ========================================
// 통합 schema의 도메인 섹션 — packages/pbc-hr-payroll가 소유.
// 모델 변경 시 packages/pbc-hr-payroll의 Prisma store 어댑터
// (attendance/leave/nomu prismaStore.ts) 동기화 필수.
// 결정 (spec §10): Prisma multi-schema 1차 보류 → 통합 schema의
// 섹션 분리만 적용 (빌드 단순).

enum EmploymentType {
  FULL_TIME
  CONTRACT
  DAILY
  PART_TIME
}

enum SalaryType {
  MONTHLY
  HOURLY
  DAILY
}

enum AttendanceMethod {
  QR
  IP
  GPS
  MANUAL
}

enum AttendanceStatus {
  NORMAL
  LATE
  EARLY_LEAVE
  ABSENT
}

enum LeaveType {
  ANNUAL
  SICK
  CONDOLENCE
  MATERNITY
  PATERNITY
  OTHER
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum PayrollStatus {
  DRAFT
  CALCULATED
  PAID
  CANCELLED
}

model Employment {
  id             String         @id @default(cuid())
  userId         String
  organizationId String
  type           EmploymentType
  salaryType     SalaryType
  baseSalary     Decimal        @db.Decimal(14, 2)
  hourlyRate     Decimal?       @db.Decimal(12, 2)
  startedAt      DateTime
  endedAt        DateTime?

  user         User         @relation("EmploymentUser", fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation("EmploymentOrg", fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, userId])
  @@index([userId])
}

model Attendance {
  id             String           @id @default(cuid())
  userId         String
  organizationId String
  checkInAt      DateTime
  checkOutAt     DateTime?
  method         AttendanceMethod
  status         AttendanceStatus @default(NORMAL)
  reason         String?

  user         User         @relation("AttendanceUser", fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation("AttendanceOrg", fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, checkInAt])
  @@index([organizationId, checkInAt])
}

model Payroll {
  id                 String        @id @default(cuid())
  userId             String
  organizationId     String
  // WI-620 — Multi-org tenancy pilot. Null = self-org (single-org tier or
  // legacy rows). Set to a ManagedOrg.id when the payroll record belongs to
  // a managed (위탁) org. All payroll queries should filter on tenantOrgId.
  tenantOrgId        String?
  periodYear         Int
  periodMonth        Int
  gross              Decimal       @db.Decimal(14, 2)
  net                Decimal       @db.Decimal(14, 2)
  status             PayrollStatus @default(DRAFT)
  insuranceRatesYear Int

  user         User          @relation("PayrollUser", fields: [userId], references: [id], onDelete: Cascade)
  organization Organization  @relation("PayrollOrg", fields: [organizationId], references: [id], onDelete: Cascade)
  items        PayrollItem[]

  calculatedAt DateTime?
  paidAt       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, periodYear, periodMonth])
  @@index([organizationId, periodYear, periodMonth])
  @@index([tenantOrgId])
}

model PayrollItem {
  id        String  @id @default(cuid())
  payrollId String
  category  String
  type      String
  amount    Decimal @db.Decimal(14, 2)

  payroll Payroll @relation(fields: [payrollId], references: [id], onDelete: Cascade)

  @@index([payrollId])
}

model Leave {
  id              String      @id @default(cuid())
  userId          String
  organizationId  String
  type            LeaveType
  startDate       DateTime
  endDate         DateTime
  days            Int
  status          LeaveStatus @default(PENDING)
  reason          String?
  approverId      String?
  rejectionReason String?

  user         User         @relation("LeaveUser", fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation("LeaveOrg", fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, startDate])
  @@index([organizationId, startDate])
}

model NomuConsultation {
  id                 String   @id @default(cuid())
  organizationId     String
  userId             String?
  question           String
  redactedQuestion   String
  topicCategory      String
  topicConfidence    Float
  answer             String
  citations          String[]
  validationValid    Boolean?
  validationReason   String?
  validationWarnings String[] @default([])

  organization Organization @relation("NomuOrg", fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation("NomuUser", fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, createdAt])
}

model WorkSchedule {
  id             String @id @default(cuid())
  userId         String
  organizationId String
  dayOfWeek      Int
  startTime      String
  endTime        String
  graceMinutes   Int    @default(0)

  user         User         @relation("WorkScheduleUser", fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation("WorkScheduleOrg", fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, dayOfWeek])
  @@index([organizationId])
}

// =====================================================================
// WI-616: Module system installation registry.
// One row per (org, module) install. Settings is reserved for module-
// specific configuration (e.g. per-org tax rates for the payroll module).
// Pack install (installPack) writes N rows in a single transaction at
// the application layer.
// =====================================================================
model OrgModuleInstall {
  id          String   @id @default(cuid())
  orgId       String
  moduleId    String
  installedAt DateTime @default(now())
  settings    Json?

  @@unique([orgId, moduleId])
  @@index([orgId])
}

// =====================================================================
// WI-620: Multi-org tenancy — premium tier where a consulting org can
// host N managed orgs (위탁 운영). ManagedOrg rows describe each guest
// org; OrgMultiOrgSubscription tracks whether the owner org has the
// feature enabled and how many managed orgs they may add.
//
// Module tables that participate in multi-org (Pack A finance/analytics,
// Pack B matching/journals, Pack D fully) carry a `tenantOrgId` column
// that points at either ManagedOrg.id (managed scope) or null (self).
// =====================================================================
enum ManagedOrgStatus {
  ACTIVE
  PAUSED
  TERMINATED
}

model ManagedOrg {
  id             String           @id @default(cuid())
  // The owner is the consulting/parent org that pays + administers.
  ownerOrgId     String
  name           String
  bizRegNumber   String?
  status         ManagedOrgStatus @default(ACTIVE)
  // Pack ids that have been delegated to this managed org (e.g. ["D"]).
  installedPacks Json             @default("[]")
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([ownerOrgId])
  @@index([ownerOrgId, status])
}

model OrgMultiOrgSubscription {
  id          String    @id @default(cuid())
  orgId       String    @unique
  enabled     Boolean   @default(false)
  // Plan-level cap on simultaneous managed orgs (0 = unlimited disabled).
  maxManaged  Int       @default(0)
  activatedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ========================================
// Phase 20: Pack F ERP + Receipt OCR Intake (WI-705)
// spec: docs/specs/2026-05-15-phase20-erp-receipt-intake-design.md §4
// ========================================

model Product {
  id        String   @id @default(cuid())
  orgId     String // Multi-org: managed org id로도 사용
  sku       String?
  name      String
  unit      String // 개, 박스, kg
  unitPrice Decimal  @default(0) // KRW
  category  String?
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  movements  InventoryMovement[]
  orderItems OrderItem[]

  @@unique([orgId, sku]) // sku 부재 시 nullable이라 collision 없음
  @@index([orgId, name])
  @@index([orgId, archived])
}

model InventoryMovement {
  id         String         @id @default(cuid())
  orgId      String
  productId  String
  type       MovementType // IN | OUT | ADJUST
  qty        Int // unsigned (양수). 방향은 type이 결정.
  source     ReferenceType?
  sourceId   String?
  unitCost   Decimal?
  note       String?
  occurredAt DateTime
  createdAt  DateTime       @default(now())

  product Product @relation(fields: [productId], references: [id])

  @@index([orgId, productId, occurredAt])
  @@index([orgId, occurredAt])
}

model Order {
  id               String         @id @default(cuid())
  orgId            String
  type             OrderType // SALE | PURCHASE
  counterpartyId   String? // free-form snapshot (FK 없음, Phase 21에 ErpCounterparty FK 도입)
  counterpartyName String // 표시용 snapshot
  status           OrderStatus // DRAFT | CONFIRMED | CANCELLED
  total            Decimal
  tax              Decimal        @default(0)
  occurredAt       DateTime
  source           ReferenceType?
  sourceId         String?
  note             String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  items OrderItem[]

  @@index([orgId, type, occurredAt])
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String? // null = ad-hoc item (사전등록 안 된 품목, InventoryMovement 미생성)
  productName String // snapshot
  qty         Int
  unitPrice   Decimal
  lineTotal   Decimal

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])
}

model IntakeDraft {
  id               String      @id @default(cuid())
  orgId            String
  userId           String? // nullable — onDelete: SetNull 요건 (Plan review C9 fix)
  blobUrl          String // 영수증 이미지 (Vercel Blob, public unguessable URL — Phase 20 MVP. signed URL은 Phase 21+)
  ocrJson          Json // raw OCR 결과
  parsedJson       Json // 구조화된 추출 결과
  matchSuggestions Json // product/client 매칭 후보 (Decimal은 string으로 변환 후 저장 — Plan review M9 fix)
  status           DraftStatus // PENDING | CONFIRMED | DISCARDED
  confirmedOrderId String? // unique (한 draft → 한 Order)
  errorMsg         String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([confirmedOrderId]) // 멱등성 1차 방어
  @@index([orgId, status, createdAt])
  @@index([orgId, userId, status])
}

enum MovementType {
  IN
  OUT
  ADJUST
}

enum ReferenceType {
  RECEIPT_INTAKE
  ORDER
  MANUAL
  INITIAL
}

enum OrderType {
  SALE
  PURCHASE
}

enum OrderStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

enum DraftStatus {
  PENDING
  CONFIRMED
  DISCARDED
}
