"<section class="pbc-block pbc-A1 pbc-A1--full-bleed" data-block-id="A1"><div class="pbc-A1__inner" style="background-image:url('placeholder://hero')"><h1 class="pbc-A1__headline">[Product name]</h1><p class="pbc-A1__tagline">[Single-line value proposition]</p></div></section>

<section class="pbc-block pbc-B2 pbc-B2--side-by-side" data-block-id="B2"><div class="pbc-B2__pair"><figure class="pbc-B2__before"><figcaption><strong>Before</strong> <span>[The customer&#39;s pain point]</span></figcaption></figure><figure class="pbc-B2__after"><figcaption><strong>After</strong> <span>[The transformation your product delivers]</span></figcaption></figure></div><p class="pbc-B2__caption">[One-line caption]</p></section>

<section class="pbc-block pbc-B1 pbc-B1--icon-grid" data-block-id="B1"><ul class="pbc-B1__list"><li class="pbc-B1__item"><h3 class="pbc-B1__title">[Key benefit 1]</h3><p class="pbc-B1__desc">[Two-sentence explanation grounded in real customer outcomes.]</p></li><li class="pbc-B1__item"><h3 class="pbc-B1__title">[Key benefit 2]</h3><p class="pbc-B1__desc">[Two-sentence explanation grounded in real customer outcomes.]</p></li><li class="pbc-B1__item"><h3 class="pbc-B1__title">[Key benefit 3]</h3><p class="pbc-B1__desc">[Two-sentence explanation grounded in real customer outcomes.]</p></li></ul></section>

<section class="pbc-block pbc-C2 pbc-C2--review-card" data-block-id="C2"><p class="pbc-C2__summary">4.8 / 5 (0)</p><ul class="pbc-C2__list"><li class="pbc-C2__review"><div class="pbc-C2__rating" aria-label="5 of 5">5</div><blockquote class="pbc-C2__quote">[Replace with a real customer quote]</blockquote><cite class="pbc-C2__cite">[Customer name] · YYYY-MM-DD</cite></li></ul></section>

<section class="pbc-block pbc-D1 pbc-D1--simple-table" data-block-id="D1"><table class="pbc-D1__table"><caption>Specifications</caption><tbody><tr><th scope="row">Material</th><td>[e.g. Aluminum 6061]</td></tr><tr><th scope="row">Weight</th><td>[e.g. 1.2kg]</td></tr><tr><th scope="row">Origin</th><td>[e.g. Made in Korea]</td></tr></tbody></table></section>

<section class="pbc-block pbc-D3 pbc-D3--grid-layout" data-block-id="D3"><ul class="pbc-D3__list"><li class="pbc-D3__item"><span class="pbc-D3__name">Main product</span><span class="pbc-D3__qty">×1</span></li><li class="pbc-D3__item"><span class="pbc-D3__name">User manual</span><span class="pbc-D3__qty">×1</span></li><li class="pbc-D3__item"><span class="pbc-D3__name">Warranty card</span><span class="pbc-D3__qty">×1</span></li></ul></section>

<section class="pbc-block pbc-F2 pbc-F2--swatch-grid" data-block-id="F2"><ul class="pbc-F2__list"><li class="pbc-F2__option"><span class="pbc-F2__swatch" style="background-color:#111111" aria-hidden="true"></span><span class="pbc-F2__name">Black</span></li><li class="pbc-F2__option"><span class="pbc-F2__swatch" style="background-color:#FAFAFA" aria-hidden="true"></span><span class="pbc-F2__name">White</span></li><li class="pbc-F2__option" data-unavailable="true"><span class="pbc-F2__swatch" style="background-color:#D6C9A8" aria-hidden="true"></span><span class="pbc-F2__name">Sand</span></li></ul></section>

<section class="pbc-block pbc-E2 pbc-E2--coupon-card" data-block-id="E2"><h3 class="pbc-E2__title">First-purchase discount</h3><span class="pbc-E2__discount">10% off</span><code class="pbc-E2__code">WELCOME10</code><time class="pbc-E2__expiry">~2026-12-31</time></section>

<section class="pbc-block pbc-E4 pbc-E4--info-box" data-block-id="E4"><div class="pbc-E4__shipping"><strong>Shipping</strong> Free shipping on orders over ₩50,000</div><div class="pbc-E4__return"><strong>Returns</strong> 30-day exchange / return policy</div><dl class="pbc-E4__policies"><dt>Order cutoff</dt><dd>2 PM KST same-day shipping</dd><dt>Carrier</dt><dd>CJ Logistics</dd></dl></section>

<section class="pbc-block pbc-E1 pbc-E1--sticky-bottom" data-block-id="E1"><div class="pbc-E1__price-block"><span class="pbc-E1__original">₩49,000</span><span class="pbc-E1__price">₩39,000</span></div><p class="pbc-E1__urgency">Only a few left in stock</p><a class="pbc-E1__cta" href="/cart/add">Add to cart</a></section>"
