"<section class="pbc-block pbc-A1 pbc-A1--split-half" data-block-id="A1"><div class="pbc-A1__inner"><h1 class="pbc-A1__headline">[Document title]</h1><p class="pbc-A1__tagline">[Subtitle / engagement reference]</p></div></section>

<section class="pbc-block pbc-C4 pbc-C4--mission-statement" data-block-id="C4"><h2 class="pbc-C4__headline">About</h2><div class="pbc-C4__body">[One-paragraph organizational summary tailored to this audience.]</div></section>

<section class="pbc-block pbc-A3 pbc-A3--question-list" data-block-id="A3"><p class="pbc-A3__intro">Problem we are solving</p><ul class="pbc-A3__list"><li class="pbc-A3__point">[Pain point 1 — concrete and measurable]</li><li class="pbc-A3__point">[Pain point 2 — concrete and measurable]</li><li class="pbc-A3__point">[Pain point 3 — concrete and measurable]</li></ul></section>

<section class="pbc-block pbc-B1 pbc-B1--number-list" data-block-id="B1"><ul class="pbc-B1__list"><li class="pbc-B1__item"><h3 class="pbc-B1__title">[Solution component 1]</h3><p class="pbc-B1__desc">[How it addresses the problem above.]</p></li><li class="pbc-B1__item"><h3 class="pbc-B1__title">[Solution component 2]</h3><p class="pbc-B1__desc">[How it addresses the problem above.]</p></li><li class="pbc-B1__item"><h3 class="pbc-B1__title">[Solution component 3]</h3><p class="pbc-B1__desc">[How it addresses the problem above.]</p></li></ul></section>

<section class="pbc-block pbc-C5 pbc-C5--stat-card" data-block-id="C5"><ul class="pbc-C5__list"><li class="pbc-C5__item"><span class="pbc-C5__value">[KPI value]</span><span class="pbc-C5__label">Expected impact</span></li><li class="pbc-C5__item"><span class="pbc-C5__value">[Weeks or months]</span><span class="pbc-C5__label">Timeline</span></li><li class="pbc-C5__item"><span class="pbc-C5__value">[Headcount]</span><span class="pbc-C5__label">Team</span></li></ul></section>

<section class="pbc-block pbc-D1 pbc-D1--simple-table" data-block-id="D1"><table class="pbc-D1__table"><caption>Scope</caption><tbody><tr><th scope="row">In scope</th><td>[Bullet 1, bullet 2]</td></tr><tr><th scope="row">Out of scope</th><td>[Bullet 1, bullet 2]</td></tr><tr><th scope="row">Assumptions</th><td>[Bullet 1, bullet 2]</td></tr></tbody></table></section>

<section class="pbc-block pbc-D2 pbc-D2--step-list" data-block-id="D2"><ol class="pbc-D2__steps"><li class="pbc-D2__step"><h4>Discovery</h4><p>[Goals and success criteria.]</p></li><li class="pbc-D2__step"><h4>Design</h4><p>[Architecture and review gates.]</p></li><li class="pbc-D2__step"><h4>Build</h4><p>[Iteration plan and demos.]</p></li><li class="pbc-D2__step"><h4>Launch</h4><p>[Rollout and acceptance.]</p></li></ol></section>

<section class="pbc-block pbc-E4 pbc-E4--policy-table" data-block-id="E4"><div class="pbc-E4__shipping"><strong>Shipping</strong> [Delivery / hand-off terms]</div><div class="pbc-E4__return"><strong>Returns</strong> [Revision / change-order policy]</div><dl class="pbc-E4__policies"><dt>Payment</dt><dd>[Milestones or schedule]</dd><dt>Confidentiality</dt><dd>[NDA reference]</dd></dl></section>"
`;

